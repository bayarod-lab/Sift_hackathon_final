# Ignore Aider internal state files
.aider*

# Ignore generated outputs
exports/
__pycache__/

# NEVER UPLOAD API KEYS
.env

# Ignore raw forensic binaries and massive text dumps
*.raw
*.img
*.pcap
*memory_scan_results.txt
*.[eE]01
*.zip
*.edb
*.ost
*.csv

# Ignore the entire data directory EXCEPT the specific log files we want
data/

# FORCE KEEP STRUCTURED LOGS FOR JUDGES (Hackathon Requirement)
# (If you ended up naming the folder 'cases' instead of 'data', 
# change 'data' to 'cases' in the lines below and above)
!data/
!data/*/
!data/*/triage_ledger.json
!data/*/actions.jsonl
!data/*/critique.txt

# Ignore messy extraction folders specifically
data/*/extractions/
